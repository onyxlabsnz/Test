---
---
<header class="navbar-onyx">
  <nav class="nav-onyx" id="navMain">
    <div class="nav-wrap">
      <a class="nav-brand" href="/">
        <img src="/onyx-labs-logo.svg" alt="Onyx Labs" class="logo-mark" width="140" height="44" />
      </a>
      <button type="button" class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" id="navToggle">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <div class="nav-menu">
        <ul class="nav-list">
          <li class="nav-item dropdown">
            <a href="#" class="nav-link dropdown-toggle" role="button" aria-haspopup="true" aria-expanded="false">Services</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/ai-governance">AI Governance</a></li>
              <li><a class="dropdown-item" href="/ai-training">AI Training</a></li>
              <li><a class="dropdown-item" href="/ai-consulting">AI Consulting</a></li>
              <li><a class="dropdown-item" href="/ai-development">AI Development</a></li>
              <li><hr class="dropdown-divider" /></li>
              <li><a class="dropdown-item" href="/web-development">Web Development</a></li>
              <li><a class="dropdown-item" href="/web-hosting">Web Hosting</a></li>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/about">About</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/contact">Contact</a>
          </li>
        </ul>
        <a href="/contact" class="btn btn-primary btn-sm">Get in touch</a>
      </div>
    </div>
  </nav>
</header>
<script>
  (function() {
    const nav = document.getElementById('navMain');
    const toggle = document.getElementById('navToggle');
    if (!nav || !toggle) return;
    toggle.addEventListener('click', function() {
      nav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', nav.classList.contains('open'));
    });
  })();
</script>
