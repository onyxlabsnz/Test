---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact Onyx Labs"
  description="Contact Onyx Labs to discuss AI governance, training, consulting, and development."
>
  <section class="content-main">
    <div class="container shell">
      <div class="row row-cols-2" style="gap: 1.5rem;">
        <div>
          <div class="content-kicker">Contact</div>
          <h1 class="content-heading">Tell us about your AI plans.</h1>
          <p class="content-lede">
            Share a bit about your team and what you're exploring. We'll follow up with a short
            set of questions and a time to talk.
          </p>
          <div class="pill-row">
            <span class="badge">
              <span class="badge-dot"></span>
              <span>Typical response in 1–2 business days</span>
            </span>
          </div>
          <div class="content-panel" style="margin-top: 1.4rem">
            <h3>What to expect</h3>
            <ul>
              <li>A 30–45 minute conversation with a senior consultant.</li>
              <li>No sales scripts — just a working session.</li>
              <li>Clear next steps, even if we're not the right fit.</li>
            </ul>
          </div>
        </div>
        <div>
          <div class="form-card">
            <form action="mailto:hello@example.com" method="post" enctype="text/plain" aria-label="Contact form">
              <div class="field">
                <label for="name">Name</label>
                <input id="name" name="name" type="text" required />
              </div>
              <div class="field">
                <label for="email">Work email</label>
                <input id="email" name="email" type="email" required />
              </div>
              <div class="field">
                <label for="company">Company</label>
                <input id="company" name="company" type="text" />
              </div>
              <div class="field">
                <label for="topic">What do you want to talk about?</label>
                <select id="topic" name="topic">
                  <option>AI Governance</option>
                  <option>AI Training</option>
                  <option>AI Consulting</option>
                  <option>AI Development</option>
                  <option>Web Development</option>
                  <option>Web Hosting</option>
                  <option>Something else</option>
                </select>
              </div>
              <div class="field">
                <label for="details">Anything else we should know?</label>
                <textarea id="details" name="details"></textarea>
                <p class="form-helper">
                  Please avoid sharing sensitive or confidential information at this stage.
                </p>
              </div>
              <button type="submit" class="btn btn-primary">Send message</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
